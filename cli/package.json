{
  "name": "@capx/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "capx": "./bin/capx.js"
  },
  "scripts": {
    "build": "tsup src/main.ts --format esm --out-dir bin --clean",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/main.ts"
  },
  "dependencies": {
    "@capx/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
